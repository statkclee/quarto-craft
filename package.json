{
  "name": "quarto-craft",
  "version": "1.0.0",
  "description": "Quarto Design System & Document Templates",
  "scripts": {
    "build": "sass scss/main.scss css/quarto-craft.css --style compressed --no-source-map",
    "watch": "sass scss/main.scss css/quarto-craft.css --watch",
    "dev": "sass scss/main.scss css/quarto-craft.css --style expanded --source-map"
  },
  "devDependencies": {
    "sass": "^1.77.0"
  }
}
